generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Wallet {
  id          String   @id @default(cuid())
  groupChatId String   @unique
  address     String
  privateKey  String   // encrypted at rest
  createdAt   DateTime @default(now())

  @@map("wallets")
}

model Proposal {
  id             String       @id @default(cuid())
  groupChatId    String
  marketId       String
  /// Optional side, only used for binary YES/NO markets
  side           String?      // YES | NO
  /// Polymarket outcome token id for this proposal
  outcomeTokenId String?
  /// Human-readable outcome label from Polymarket (e.g. candidate name)
  outcomeLabel   String?
  amount         Decimal     @db.Decimal(36, 18)
  proposer       String
  approvalWeight Decimal     @db.Decimal(10, 4) @default(0)
  rejectWeight   Decimal     @db.Decimal(10, 4) @default(0)
  status         ProposalStatus @default(VOTING)
  createdAt      DateTime    @default(now())
  deadline       DateTime

  votes Vote[]

  @@index([groupChatId])
  @@index([status, deadline])
  @@map("proposals")
}

enum ProposalStatus {
  VOTING
  APPROVED
  REJECTED
  EXECUTED
  EXPIRED
}

model Vote {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  vote       String   // approve | reject
  weight     Decimal  @db.Decimal(10, 4)

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
  @@index([proposalId])
  @@map("votes")
}

model Position {
  id          String         @id @default(cuid())
  groupChatId String
  marketId    String
  /// Optional side, only used for binary YES/NO markets
  side        String?        // YES | NO
  /// Polymarket outcome token id this position is in
  outcomeTokenId String?
  /// Human-readable outcome label from Polymarket (e.g. candidate name)
  outcomeLabel   String?
  shares      Decimal        @db.Decimal(36, 18)
  avgPrice    Decimal        @db.Decimal(36, 18)
  currentPrice Decimal       @db.Decimal(36, 18)
  status      PositionStatus @default(OPEN)
  executedAt  DateTime       @default(now())
  closedAt    DateTime?
  txHash      String?

  @@index([groupChatId])
  @@index([marketId, groupChatId, status])
  @@map("positions")
}

enum PositionStatus {
  OPEN
  CLOSED
}
