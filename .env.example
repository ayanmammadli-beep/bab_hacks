# Server
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/polymarket_bot?schema=public"

# Wallet encryption (32-byte hex for AES-256)
WALLET_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Polymarket
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYGON_CHAIN_ID=137

# Voting
DEFAULT_APPROVAL_WEIGHT=0.6

# Off-chain prediction markets (group-created)
PREDICTION_APPROVAL_THRESHOLD=0.6
PREDICTION_RESOLUTION_THRESHOLD=0.6
PREDICTION_RESOLUTION_WINDOW_HOURS=24

# Liquid (tryliquid.xyz). Create keys only after: 1) Deposit USDC, 2) Enable Trading on /trade
# Keys: https://app.tryliquid.xyz/account/api-keys
LIQUID_API_KEY=
LIQUID_API_SECRET=
# Optional: override API base URL
# LIQUID_BASE_URL=https://prometheus-prod--liquid-public-api-public-fastapi-app.modal.run
