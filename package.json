{
  "name": "polymarket-group-bot",
  "version": "1.0.0",
  "description": "Backend service for group chat bot interacting with Polymarket on Polygon",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "setup-env": "node scripts/setup-env.js",
    "test:api": "node scripts/test-api.js"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "@polymarket/clob-client": "^5.8.0",
    "@prisma/client": "^6.0.0",
    "ethers": "^5.7.2",
    "express": "^4.21.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
